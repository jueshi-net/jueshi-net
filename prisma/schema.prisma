generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(cuid())
  name                 String?
  email                String             @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 String             @default("user")
  points               Int                @default(0)       // 积分缓存
  checkinStreak        Int                @default(0)       // 连续签到天数
  lastCheckinDate      String?            // 最后一次签到日期 YYYY-MM-DD
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  accounts             Account[]
  auditLogs            AuditLog[]
  favorites            Favorite[]
  feedback             Feedback[]
  links                LinkItem[]
  memos                Memo[]
  notifications        Notification[]
  sessions             Session[]
  shortLinks           ShortLink[]
  preferences          UserPreference?
  subscriptions        UserSubscription[]
  webhooks             Webhook[]
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]        @relation("WorkspaceOwner")
  pointLedgers         PointLedger[]
  dailyCheckIns        DailyCheckIn[]
  userTasks            UserTask[]

  @@map("users")
}

model UserPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("system")
  language        String   @default("zh-CN")
  emailNotif      Boolean  @default(true)
  compactMode     Boolean  @default(false)
  itemsPerPage    Int      @default(20)
  defaultCategory String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model LinkItem {
  id           String     @id @default(cuid())
  title        String
  url          String
  description  String?
  icon         String?
  categoryName String?
  categoryId   String?
  userId       String?
  workspaceId  String?
  sortOrder    Int        @default(0)
  isPinned     Boolean    @default(false)
  isFeatured   Boolean    @default(false)
  clicks       Int        @default(0)
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  favorites    Favorite[]
  tags         LinkTag[]
  category     Category?  @relation(fields: [categoryId], references: [id])
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([userId])
  @@index([workspaceId])
  @@map("links")
}

model Category {
  id        String     @id @default(cuid())
  name      String     @unique
  slug      String     @unique
  icon      String?
  color     String?
  sortOrder Int        @default(0)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  links     LinkItem[]

  @@map("categories")
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  links     LinkTag[]

  @@map("tags")
}

model LinkTag {
  id        String   @id @default(cuid())
  linkId    String
  tagId     String
  createdAt DateTime @default(now())
  link      LinkItem @relation(fields: [linkId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([linkId, tagId])
  @@map("link_tags")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  linkId    String
  createdAt DateTime @default(now())
  link      LinkItem @relation(fields: [linkId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, linkId])
  @@map("favorites")
}

model Memo {
  id        String   @id @default(cuid())
  title     String
  content   String?
  category  String?
  userId    String
  isPinned  Boolean  @default(false)
  color     String?
  dueDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("memos")
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  description String?
  icon        String?
  ownerId     String
  isPublic    Boolean           @default(false)
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  links       LinkItem[]
  members     WorkspaceMember[]
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  role        String    @default("member")
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model ShortLink {
  id          String    @id @default(cuid())
  code        String    @unique
  url         String
  userId      String?
  title       String?
  description String?
  expiresAt   DateTime?
  password    String?
  clicks      Int       @default(0)
  lastClickAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("short_links")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  subject   String
  content   String
  page      String?
  email     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AdSlot {
  id          String    @id @default(cuid())
  name        String    @unique
  position    String
  imageUrl    String
  linkUrl     String
  altText     String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  clicks      Int       @default(0)
  impressions Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ad_slots")
}

model Article {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  content     String
  excerpt     String?
  coverImage  String?
  author      String?
  status      String       @default("draft")
  views       Int          @default(0)
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    String?      // 文章分类：跨境寄送/海外生活/出海经营
  seoTitle    String?       // SEO 标题
  seoDescription String?   // SEO 描述
  relatedTools  String[] @default([]) // 关联工具路由
  tags        ArticleTag[]

  @@index([status])
  @@index([category])
  @@map("articles")
}

model ArticleTag {
  id        String   @id @default(cuid())
  articleId String
  tag       String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, tag])
  @@map("article_tags")
}

model Resource {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  category    String   // life/logistics/business/templates
  tags        String[] @default([])
  sourceType  String   @default("third-party") // official/third-party/internal
  usage       String?  // 适用场景/使用提示
  disclaimer  String?  // 免责声明或使用提示
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("resources")
}

model Subscription {
  id          String             @id @default(cuid())
  name        String             @unique
  slug        String             @unique
  description String?
  price       Float
  interval    String
  features    String?
  isActive    Boolean            @default(true)
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  users       UserSubscription[]

  @@map("subscriptions")
}

model UserSubscription {
  id                String       @id @default(cuid())
  userId            String
  subscriptionId    String
  status            String       @default("active")
  startDate         DateTime     @default(now())
  endDate           DateTime?
  cancelAtPeriodEnd Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subscriptionId])
  @@map("user_subscriptions")
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  price       Float
  interval    String
  features    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("subscription_plans")
}

model Webhook {
  id            String    @id @default(cuid())
  userId        String?
  url           String
  events        String
  secret        String?
  isActive      Boolean   @default(true)
  lastTriggered DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("webhooks")
}

model EmailSubscription {
  id          String    @id @default(cuid())
  email       String    @unique
  token       String?
  confirmed   Boolean   @default(false)
  isActive    Boolean   @default(true)
  confirmedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("email_subscriptions")
}

model NewsletterBroadcast {
  id        String   @id @default(cuid())
  subject   String
  content   String
  status    String   @default("draft")
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletter_broadcasts")
}

model PostalCode {
  id            String   @id @default(cuid())
  country       String
  countryCode   String
  province      String?
  city          String
  district      String?
  postalCode    String
  normalizedPostalCode String?  // 去空格/横线的大写版本，如 V6B0A1, SW1A1AA
  areaName      String?
  adminName1    String?  // 省/州名
  adminCode1    String?  // 省/州缩写
  adminName2    String?
  adminCode2    String?
  latitude      Float?
  longitude     Float?
  accuracy      Int?     // 精度等级 1-6
  isActive      Boolean  @default(true)
  source        String   @default("GeoNames")
  sourceUrl     String   @default("https://download.geonames.org/export/zip/")
  sourceVersion String?  // import date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([countryCode, postalCode])
  @@index([postalCode])
  @@index([normalizedPostalCode])
  @@index([countryCode, normalizedPostalCode])
  @@index([country, city])
  @@index([countryCode, postalCode])
  @@index([countryCode, city])
  @@index([adminCode1])
  @@map("postal_codes")
}

model HSCode {
  id            String   @id @default(cuid())
  code          String   @unique
  level         Int
  parentId      String?
  description   String
  descriptionEn String?
  category      String?
  taxRate       Float?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  parent        HSCode?  @relation("HSHierarchy", fields: [parentId], references: [id])
  children      HSCode[] @relation("HSHierarchy")

  @@index([category])
  @@index([description])
  @@map("hs_codes")
}

// 导出日志：用于追踪每日导出次数和权限审计
model ExportLog {
  id            String   @id @default(cuid())
  userId        String?  // null for guest attempts
  exportType    String   // word/png/pdf/document/label
  documentType  String?  // commercial-invoice/quotation/packing-list/label-maker etc
  ipHash        String?  // anonymized IP
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([exportType])
  @@index([createdAt])
  @@map("export_logs")
}

// 匿名统计埋点：只记录事件类型/工具名/路径/时间，不采集用户输入内容
model EventLog {
  id          String   @id @default(cuid())
  eventType   String         // tool_click / tool_copy / tool_calculate / tool_query / article_click / resource_click / memo_action
  toolName    String?          // tracking / shipping-calculator / hs-code / postal-code / exchange-rate / memo / resources / blog
  action      String?  // 具体动作，如 copy_tracking_number / click_17track / convert_currency / add_memo 等
  path        String?  // 页面路径，如 /tools/tracking
  sessionId   String?         // 匿名 sessionId（localStorage 生成，不关联用户身份）
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([toolName])
  @@index([createdAt])
  @@index([sessionId])
  @@map("event_logs")
}

// 积分流水：所有积分变动必须写入此表
model PointLedger {
  id          String   @id @default(cuid())
  userId      String
  type        String         // daily_checkin / task_complete / export_word / admin_adjust / reward_redeem
  points      Int            // 正数=增加，负数=扣减
  reason      String?        // 说明文字，如"每日签到"、"完成任务"
  relatedId   String?        // 关联记录 ID（如 task ID、checkin ID）
  metadata    Json?          // 额外元数据
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("point_ledgers")
}

// 每日签到：防止重复签到
model DailyCheckIn {
  id          String   @id @default(cuid())
  userId      String
  dateKey     String         // YYYY-MM-DD
  points      Int            // 获得的积分数
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId])
  @@index([dateKey])
  @@map("daily_check_ins")
}

// 用户待办任务
model UserTask {
  id             String   @id @default(cuid())
  userId         String
  title          String
  description    String?
  status         String   @default("pending")   // pending / done / archived
  priority       String   @default("normal")    // low / normal / high
  category       String?
  dueDate        DateTime?
  completedAt    DateTime?
  pointsAwarded  Boolean  @default(false)        // 是否已发放积分
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@map("user_tasks")
}
