# Cloudflare R2 异地备份配置
# 复制此文件为 .env.backup 并填入实际值
#
# 获取方式：
# 1. 登录 Cloudflare Dashboard → R2
# 2. 创建 Bucket（如 xixiong-saas-backups）
# 3. 管理 API 令牌 → 创建令牌（Object Read & Write）
# 4. 填写以下字段

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=xixiong-saas-backups
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BACKUP_PREFIX=xixiong-saas/postgres
